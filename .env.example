# Copy this file to `.env` and fill in your key.
# Never commit `.env` (it is gitignored).

# ---- Provider selection ----
# Options: "anthropic" (default) | "nvidia"
LLM_PROVIDER=anthropic

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6   # default if unset

# ---- NVIDIA (OpenAI-compatible, free tier available at build.nvidia.com) ----
# NVIDIA_API_KEY=nvapi-...
# Default model is a non-reasoning instruct model. Reasoning models (DeepSeek-R1,
# minimax) emit long <think>...</think> preambles that blow through the token budget.
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
